{
  "name": "@bg-dev/nuxt-auth",
  "version": "3.0.3",
  "license": "MIT",
  "type": "module",
  "author": "Becem Gharbi",
  "homepage": "https://nuxt-auth.bg.tn",
  "keywords": [
    "nuxt",
    "auth",
    "oauth",
    "edge"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "dev:build:ssr": "cross-env NUXT_SSR=true NODE_OPTIONS=--no-deprecation nuxi build playground",
    "dev:build:spa": "cross-env NUXT_SSR=false NODE_OPTIONS=--no-deprecation nuxi build playground",
    "dev:preview": "nuxt preview playground",
    "test": "cross-env NUXT_SSR=true NODE_OPTIONS=--no-deprecation playwright test --ui",
    "test:prod:ssr": "cross-env NUXT_SSR=true NODE_OPTIONS=--no-deprecation playwright test",
    "test:prod:spa": "cross-env NUXT_SSR=false NODE_OPTIONS=--no-deprecation playwright test",
    "test:prod": "npm run test:prod:ssr && npm run test:prod:spa",
    "lint": "eslint .",
    "typecheck": "nuxi typecheck",
    "prepack": "nuxt-module-build build --stub",
    "release:pre": "npm run lint && npm run prepack",
    "release": "npm run release:pre && npm run test:prod && changelogen --release && npm publish && git push --follow-tags",
    "prisma:generate": "cd playground && prisma generate",
    "prisma:migrate": "cd playground && prisma migrate dev",
    "prisma:push": "cd playground && prisma db push",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "bcrypt-ts": "^8.0.1",
    "jose": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.1.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^6.4.1",
    "@types/node": "^22.13.4",
    "changelogen": "^0.5.7",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.1",
    "nuxt": "^4.3.1",
    "vitepress": "^1.6.3"
  },
  "repository": {
    "url": "git+https://github.com/becem-gharbi/nuxt-auth.git"
  },
  "peerDependencies": {
    "defu": "latest",
    "ufo": "latest",
    "unstorage": "latest"
  },
  "packageManager": "pnpm@9.15.2+sha512.93e57b0126f0df74ce6bff29680394c0ba54ec47246b9cf321f0121d8d9bb03f750a705f24edc3c1180853afd7c2c3b94196d0a3d53d3e069d9e2793ef11f321"
}